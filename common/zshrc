CASE_SENSITIVE=true
ZSH_DISABLE_COMPFIX=true

# completions — generate once to ~/.zfunc, picked up by compinit
fpath=("$HOME/.zfunc" $fpath)
() {
    local zfunc="$HOME/.zfunc"
    mkdir -p "$zfunc"
    command -v rustup  &>/dev/null && [[ ! -f "$zfunc/_rustup" ]] && rustup completions zsh        > "$zfunc/_rustup"
    command -v rustup  &>/dev/null && [[ ! -f "$zfunc/_cargo"  ]] && rustup completions zsh cargo  > "$zfunc/_cargo"
    command -v kubectl &>/dev/null && [[ ! -f "$zfunc/_kubectl" ]] && kubectl completion zsh        > "$zfunc/_kubectl"
}

# antidote
autoload -Uz compinit && compinit
[[ -d "$HOME/.antidote" ]] || git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
source "$HOME/.antidote/antidote.zsh"
antidote load

autoload -U promptinit; promptinit
prompt spaceship

HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_DUPS HIST_FIND_NO_DUPS SHARE_HISTORY INC_APPEND_HISTORY

autoload -U up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey "^[[A" up-line-or-beginning-search   # standard
bindkey "^[OA" up-line-or-beginning-search   # application cursor (tmux)
bindkey "^[[B" down-line-or-beginning-search
bindkey "^[OB" down-line-or-beginning-search

export LANG=en_US.UTF-8
export LANGUAGE=en_US:en_GB:en
export TERM='screen-256color'
export LC_ALL=en_US.utf-8
export LC_CTYPE=en_US.utf-8
export EDITOR=nvim
export PGHOST=localhost
export GPG_TTY=$(tty)

# Customize to your needs...
alias less='less -r'
alias vi='nvim'
alias tmux='tmux -2'

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ] ; then
    PATH="$HOME/bin:$PATH"
fi

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_OPTS='
  --color fg:-1,bg:-1,hl:230,fg+:3,bg+:233,hl+:229
  --color info:150,prompt:110,spinner:150,pointer:167,marker:174
'

if [ -f ~/.localrc ] ; then
    source ~/.localrc
fi

PYTHONSTARTUP=~/.pythonrc.py
export PYTHONSTARTUP

export PATH="$HOME/.local/bin:$PATH"
eval "$(uv generate-shell-completion zsh)"
eval "$(uvx --generate-shell-completion zsh)"
